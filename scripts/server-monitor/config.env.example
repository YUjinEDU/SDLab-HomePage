# SD Lab Server Monitor — Environment Configuration
#
# Copy this file to config.env and fill in the values.
#   cp config.env.example config.env
#
# The SERVER_ID must match a UUID in the Supabase `servers` table.

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SERVER_ID=your-server-uuid-from-servers-table

# Collection interval in seconds (default: 60)
COLLECTION_INTERVAL=60

# Comma-separated list of base paths to scan for per-user disk usage.
# Each path's immediate subdirectories are measured with `du -sb`.
DISK_USAGE_PATHS=/home,/mnt/hdd1,/mnt/hdd2

# How often to run per-user disk usage scan, in seconds (default: 86400 = 24h)
DISK_USAGE_INTERVAL=86400
