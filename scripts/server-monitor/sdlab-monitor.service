[Unit]
Description=SD Lab Server Monitor Agent
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=root
WorkingDirectory=/opt/sdlab-monitor
ExecStart=/usr/bin/python3 /opt/sdlab-monitor/agent.py
Restart=always
RestartSec=10
EnvironmentFile=/opt/sdlab-monitor/config.env

# Security hardening
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=read-only
ReadWritePaths=/opt/sdlab-monitor

[Install]
WantedBy=multi-user.target
