# ── PostgreSQL ───────────────────────────────────────────────────────────────
# db 서비스 컨테이너가 사용하는 계정 정보
POSTGRES_USER=sdlab
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=sdlab_homepage

# ── Next.js (web 서비스) ──────────────────────────────────────────────────────
# POSTGRES_USER / POSTGRES_PASSWORD / POSTGRES_DB 와 반드시 일치해야 함
DATABASE_URL=postgresql://sdlab:change_me_strong_password@db:5432/sdlab_homepage

# openssl rand -base64 32  으로 생성
AUTH_SECRET=generate_with_openssl_rand_base64_32

# 외부에서 접근하는 URL (프로토콜 포함, 후행 슬래시 없음)
# 로컬 테스트: http://localhost:8888
# 실제 배포:   https://your-domain.ac.kr
AUTH_URL=https://your-domain.ac.kr
