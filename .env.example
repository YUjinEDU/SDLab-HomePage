# Copy this file to .env and fill in real values before running docker compose
# NEVER commit .env to version control

# PostgreSQL
POSTGRES_USER=sdlab
POSTGRES_PASSWORD=your_strong_password_here
POSTGRES_DB=sdlab_homepage

# Must match POSTGRES_USER / POSTGRES_PASSWORD / POSTGRES_DB above
DATABASE_URL=postgresql://sdlab:your_strong_password_here@db:5432/sdlab_homepage

# Auth.js secret — generate with: openssl rand -base64 32
AUTH_SECRET=replace_with_openssl_rand_output

# Public URL of the app (used for OAuth redirects and CSRF)
AUTH_URL=http://localhost:8888

# NAS mount paths (set automatically by docker-compose.yml)
# These point to the Docker volume mount inside the container
NAS_SHARED_PATH=/nas/공용
NAS_PRIVATE_PATH=/nas/개인
